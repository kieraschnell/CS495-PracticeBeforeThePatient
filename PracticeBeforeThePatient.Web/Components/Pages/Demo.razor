@page "/demo"
@rendermode InteractiveServer
@attribute [StreamRendering]
@using PracticeBeforeThePatient.Web.Services
@inject ApiClient Api
@inject AccessState AccessState
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Access</PageTitle>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div @key="_statusVersion" class="saveMessage overlayToast @StatusKind" role="status" aria-live="polite">
        @StatusMessage
    </div>
}

<div class="simShell">
    <div class="card demoCard">
        <div class="sectionTitle">Temporary Access</div>
        <div class="demoMeta">
            <div class="demoMetaRow">Current mode: @CurrentModeLabel</div>
            <div class="demoMetaRow">@CurrentModeSummary</div>
        </div>

        @if (IsAdmin)
        {
            <div class="createRow demoLoginRow">
                <button class="secondaryBtn" @onclick="LogoutAsync" disabled="@IsSaving">Return to Student Mode</button>
            </div>
        }
        else
        {
            <div class="simSubtitle">Use this page to access the admin view and in-progress testing features.</div>

            <div class="createRow demoLoginRow">
                <input class="editorInput"
                       @bind="UsernameInput"
                       @bind:event="oninput"
                       @onkeydown="OnLoginInputKeyDown"
                       placeholder="Admin username" />
                <input class="editorInput"
                       type="password"
                       @bind="PasswordInput"
                       @bind:event="oninput"
                       @onkeydown="OnLoginInputKeyDown"
                       placeholder="Admin password" />
                <button class="primaryBtn" @onclick="LoginAsync" disabled="@IsSaving">Unlock Admin</button>
            </div>
        }
    </div>
</div>

@code {
    private string UsernameInput { get; set; } = "";
    private string PasswordInput { get; set; } = "";
    private string CurrentModeLabel { get; set; } = "Student Practice";
    private string CurrentModeSummary { get; set; } = "Students can browse and run scenarios without signing in.";
    private bool IsAdmin { get; set; }
    private bool IsSaving { get; set; }
    private string StatusMessage { get; set; } = "";
    private string StatusKind { get; set; } = "success";
    private int _statusVersion;
    private string? _themeToApply;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAccessAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(_themeToApply))
        {
            await JS.InvokeVoidAsync("pbpTheme.setTheme", _themeToApply);
        }
    }

    private async Task LoginAsync()
    {
        IsSaving = true;
        StatusMessage = "";

        try
        {
            var access = await Api.LoginTemporaryAdminAsync(UsernameInput, PasswordInput);

            if (access is null)
            {
                SetStatus("Temporary admin login failed.", false);
                return;
            }

            AccessState.Update(access);
            ApplyAccess(access);
            PasswordInput = "";
            await ApplyThemeAsync(access.Theme);
            SetStatus("Admin tools unlocked for this browser session.", true);
            Nav.NavigateTo("/", forceLoad: false);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task LogoutAsync()
    {
        IsSaving = true;
        StatusMessage = "";

        try
        {
            var access = await Api.LogoutTemporaryAdminAsync();
            if (access is null)
            {
                SetStatus("Could not return to student mode.", false);
                return;
            }

            AccessState.Update(access);
            ApplyAccess(access);
            await ApplyThemeAsync(access.Theme);
            SetStatus("Student practice mode restored.", true);
            Nav.NavigateTo("/", forceLoad: false);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task OnLoginInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsSaving)
        {
            await LoginAsync();
        }
    }

    private async Task RefreshAccessAsync()
    {
        var access = AccessState.CurrentAccess ?? await Api.GetAccessAsync();
        AccessState.Update(access);
        ApplyAccess(access);
    }

    private void ApplyAccess(ApiClient.AccessResponse? access)
    {
        IsAdmin = access?.IsAdmin == true;
        CurrentModeLabel = IsAdmin ? "Admin Access" : "Student Practice";
        CurrentModeSummary = IsAdmin
            ? $"Signed in as {(!string.IsNullOrWhiteSpace(access?.Email) ? access!.Email : "temporary admin")}."
            : "Admin tools and testing features stay locked until the temporary credential is entered.";
        _themeToApply = NormalizeTheme(access?.Theme);
        UsernameInput = access?.IsAdmin == true && !string.IsNullOrWhiteSpace(access.Email)
            ? access.Email
            : UsernameInput;
    }

    private async Task ApplyThemeAsync(string? theme)
    {
        _themeToApply = NormalizeTheme(theme);
        if (!string.IsNullOrWhiteSpace(_themeToApply))
        {
            await JS.InvokeVoidAsync("pbpTheme.setTheme", _themeToApply);
        }
    }

    private void SetStatus(string message, bool ok)
    {
        StatusMessage = message;
        StatusKind = ok ? "success" : "error";
        var version = ++_statusVersion;
        _ = ClearStatusLater(version);
    }

    private async Task ClearStatusLater(int version)
    {
        await Task.Delay(3000);
        if (version != _statusVersion)
        {
            return;
        }

        StatusMessage = "";
        await InvokeAsync(StateHasChanged);
    }

    private static string? NormalizeTheme(string? theme)
    {
        if (string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase))
        {
            return "dark";
        }

        if (string.Equals(theme, "light", StringComparison.OrdinalIgnoreCase))
        {
            return "light";
        }

        return null;
    }
}
