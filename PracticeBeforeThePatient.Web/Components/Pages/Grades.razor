@page "/grades"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Globalization
@using PracticeBeforeThePatient.Web.Services
@inject ApiClient Api

<PageTitle>My Grades</PageTitle>

@if (_isLoading)
{
    <div class="simShell">
        <div class="card">
            <div class="sectionTitle">Loading</div>
            <div class="narrLine">Loading your grades</div>
        </div>
    </div>
    return;
}

@if (_isAdmin)
{
    <div class="simShell">
        <div class="card">
            <div class="sectionTitle">Not available</div>
            <div class="narrLine">This page is for students only.</div>
        </div>
    </div>
    return;
}

<div class="simShell gradingShell">
    @if (_activeGrade is not null)
    {
        <div class="submissionModePage">
            <div class="submissionModeTop">
                <div>
                    <div class="submissionFocusTitle">Graded Response: @_activeGrade.AssignmentName</div>
                    <div class="assignmentMeta">@_activeGrade.ClassName · @_activeGrade.ScenarioId</div>
                    <div class="assignmentMeta">Due: @FormatDueAtCst(_activeGrade.DueAtUtc)</div>
                </div>
                <div class="assignmentActions">
                    <button class="primaryBtn" type="button" @onclick="CloseGradeDetail">Back to Grades</button>
                </div>
            </div>

            <div>
                <label class="editorLabel">Grade</label>
                <input class="editorInput"
                       type="text"
                       value="@(_activeGrade.Grade.HasValue ? _activeGrade.Grade.Value.ToString("0.##", CultureInfo.InvariantCulture) : "Not graded yet")"
                       readonly />
            </div>

            <div>
                <label class="editorLabel">Feedback</label>
                <textarea rows="3" readonly>@(string.IsNullOrWhiteSpace(_activeGrade.GradeFeedback) ? "No feedback yet." : _activeGrade.GradeFeedback)</textarea>
            </div>

            <div>
                <label class="editorLabel">Submitted at</label>
                <input class="editorInput" type="text" value="@FormatLocal(_activeGrade.SubmittedAtUtc)" readonly />
            </div>

            <div>
                <label class="editorLabel">Graded at</label>
                <input class="editorInput" type="text" value="@FormatLocal(_activeGrade.GradedAtUtc)" readonly />
            </div>

            <label class="editorLabel">Response graded</label>
            <textarea class="submissionViewer submissionViewerFull" readonly>@(string.IsNullOrWhiteSpace(_activeGrade.SubmissionText) ? "No saved submission text." : _activeGrade.SubmissionText)</textarea>
        </div>
    }
    else
    {
        <div class="simHeaderRow">
            <div class="simHeaderText">
                <div class="simBadge">Student</div>
                <div class="simTitle">My Grades</div>
                <div class="simSubtitle">View grades, feedback, and your submitted responses</div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="card">
                <div class="sectionTitle">Error</div>
                <div class="narrLine">@_errorMessage</div>
            </div>
        }
        else if (_grades.Count == 0)
        {
            <div class="card">
                <div class="sectionTitle">No grades yet</div>
                <div class="narrLine">You do not have any graded or submitted assignments yet.</div>
            </div>
        }
        else
        {
            <div class="gradeList gradesSingleColumn">
                @foreach (var g in _grades)
                {
                    <div class="gradeCard">
                        <div class="gradeStudentRow">
                            <div class="gradeItemHeaderLine">
                                <div class="assignmentTitle">@g.AssignmentName</div>
                                <div class="assignmentMeta">@g.ClassName · @g.ScenarioId</div>
                                <div class="assignmentMeta">Due: @FormatDueAtCst(g.DueAtUtc)</div>
                            </div>
                            <div class="assignmentActions">
                                @if (!g.SubmittedAtUtc.HasValue)
                                {
                                    <div class="gradeStatus pending">Not done</div>
                                }
                                else if (!g.Grade.HasValue)
                                {
                                    <div class="gradeStatus pending">Not graded yet</div>
                                }
                                else
                                {
                                    <div class="gradeStatus done">Done</div>
                                }
                                @if (g.Grade.HasValue)
                                {
                                    <div class="gradeStatus done">Grade: @g.Grade.Value.ToString("0.##", CultureInfo.InvariantCulture)</div>
                                }
                                @if (!g.SubmittedAtUtc.HasValue)
                                {
                                    @if (IsPastDue(g.DueAtUtc))
                                    {
                                        <button class="secondaryBtn" type="button" disabled>Past due</button>
                                    }
                                    else
                                    {
                                        <a class="secondaryBtn" href="@($"simulation?assignment={g.AssignmentId}")">Go to assignment</a>
                                    }
                                }
                                else
                                {
                                    <button class="secondaryBtn" type="button" @onclick="() => OpenGradeDetail(g)">View response</button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _isAdmin;
    private string _errorMessage = "";
    private List<StudentGradeDto> _grades = new();
    private StudentGradeDto? _activeGrade;
    private static readonly TimeSpan CstOffset = TimeSpan.FromHours(-6);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var access = await Api.GetAccessAsync();
            _isAdmin = access?.IsAdmin == true;

            if (_isAdmin)
            {
                return;
            }

            _grades = await Api.Http.GetFromJsonAsync<List<StudentGradeDto>>("api/classes/me/grades")
                ?? new List<StudentGradeDto>();
        }
        catch
        {
            _errorMessage = "Could not load grades right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatDueAtCst(DateTimeOffset? dueAtUtc)
    {
        if (!dueAtUtc.HasValue)
        {
            return "No due date";
        }

        return $"{dueAtUtc.Value.ToOffset(CstOffset).ToString("MM/dd/yyyy h:mm tt", CultureInfo.InvariantCulture)} CST";
    }

    private static string FormatLocal(DateTimeOffset? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "Not available";
    }

    private static bool IsPastDue(DateTimeOffset? dueAtUtc)
    {
        return dueAtUtc.HasValue && dueAtUtc.Value < DateTimeOffset.UtcNow;
    }

    private void OpenGradeDetail(StudentGradeDto grade)
    {
        _activeGrade = grade;
    }

    private void CloseGradeDetail()
    {
        _activeGrade = null;
    }

    private sealed class StudentGradeDto
    {
        public int AssignmentId { get; set; }
        public string ClassName { get; set; } = "";
        public string AssignmentName { get; set; } = "";
        public string ScenarioId { get; set; } = "";
        public DateTimeOffset? DueAtUtc { get; set; }
        public DateTimeOffset? SubmittedAtUtc { get; set; }
        public string SubmissionText { get; set; } = "";
        public decimal? Grade { get; set; }
        public string GradeFeedback { get; set; } = "";
        public DateTimeOffset? GradedAtUtc { get; set; }
    }
}
