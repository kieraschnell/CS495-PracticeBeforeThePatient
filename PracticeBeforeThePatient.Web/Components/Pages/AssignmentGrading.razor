@page "/assignment-grading/{ClassId}/{AssignmentId}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Globalization
@using PracticeBeforeThePatient.Web.Services
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Assignment Grading</PageTitle>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div @key="_messageVersion" class="saveMessage overlayToast @_messageKind" role="status" aria-live="polite">
        @_message
    </div>
}

@if (_isLoading)
{
    <div class="card">
        <div class="sectionTitle">Loading</div>
        <div class="narrLine">Loading assignment and submissions</div>
    </div>
    return;
}

@if (!_isAdmin)
{
    <div class="card">
        <div class="sectionTitle">Not available</div>
        <div class="narrLine">This page is only available to admins</div>
    </div>
    return;
}

<div class="simShell gradingShell @(_activeSubmissionEmail is not null ? "simShellWide" : "")">
    @if (_activeSubmissionEmail is not null && _selectedClass is not null && _selectedAssignment is not null)
    {
        var activeEmail = _activeSubmissionEmail;
        var activeSubmission = GetSubmissionForStudent(activeEmail);
        var hasActiveSubmission = activeSubmission?.SubmittedAtUtc is not null;

        <div class="submissionModePage">
                <div class="submissionModeTop">
                    <div>
                        <div class="submissionFocusTitle">Submission Review: @activeEmail</div>
                        <div class="assignmentMeta">@_selectedClass.Name · @_selectedAssignment.Name · @_selectedAssignment.ScenarioId</div>
                        <div class="assignmentMeta">
                        @(hasActiveSubmission
                            ? $"Submitted {activeSubmission!.SubmittedAtUtc!.Value.ToLocalTime():g}"
                            : "No submission")
                    </div>
                </div>
                <div class="assignmentActions">
                    <button class="primaryBtn"
                            type="button"
                            @onclick="() => SaveAndBackSubmissionAsync(activeEmail)"
                            disabled="@_isSavingGrade">
                        Back to Students (Auto Save)
                    </button>
                </div>
            </div>

            <div class="gradeInputRow">
                <div>
                    <label class="editorLabel">Grade (0-100)</label>
                    <input class="editorInput"
                           type="number"
                           min="0"
                           max="100"
                           step="0.1"
                           value="@GetGradeInput(activeEmail)"
                           @oninput="(e) => SetGradeInput(activeEmail, e)" />
                </div>
                <div>
                    <label class="editorLabel">Feedback</label>
                    <textarea rows="3"
                              @bind="@_feedbackInputs[activeEmail]"
                              @bind:event="oninput"
                              placeholder="Optional feedback to student"></textarea>
                </div>
            </div>

            @if (hasActiveSubmission && !string.IsNullOrWhiteSpace(activeSubmission!.SubmissionText))
            {
                <label class="editorLabel">Submission</label>
                <textarea class="submissionViewer submissionViewerFull" readonly>@activeSubmission.SubmissionText</textarea>
            }
        </div>
    }
    else
    {
        <div class="simHeaderRow">
            <div class="simHeaderText">
                <div class="simBadge">Instructor</div>
                <div class="simTitle">Assignment Grading</div>
                <div class="simSubtitle">@_headerSubtitle</div>
            </div>

            <a class="secondaryBtn" href="class-management">Back to Class Management</a>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="card">
                <div class="sectionTitle">Error</div>
                <div class="narrLine">@_errorMessage</div>
            </div>
        }
        else if (_selectedClass is not null && _selectedAssignment is not null)
        {
            <div class="card">
            <div class="sectionTitle">Assignment</div>

            <div class="gradingMetaGrid">
                <div class="gradingMetaItem">
                    <div class="gradingMetaLabel">Class</div>
                    <div class="gradingMetaValue">@_selectedClass.Name</div>
                </div>
                <div class="gradingMetaItem">
                    <div class="gradingMetaLabel">Assignment</div>
                    <div class="gradingMetaValue">@_selectedAssignment.Name</div>
                </div>
                <div class="gradingMetaItem">
                    <div class="gradingMetaLabel">Scenario</div>
                    <div class="gradingMetaValue">@_selectedAssignment.ScenarioId</div>
                </div>
                <div class="gradingMetaItem">
                    <div class="gradingMetaLabel">Due</div>
                    <div class="gradingMetaValue">@FormatDueAtCst(_selectedAssignment.DueAtUtc)</div>
                </div>
            </div>

            @if (_assignments.Count > 1)
            {
                <div class="divider"></div>
                <label class="editorLabel">Switch assignment</label>
                <select class="editorInput" value="@_selectedAssignment.Id" @onchange="OnAssignmentChanged">
                    @foreach (var a in _assignments)
                    {
                        <option value="@a.Id">@a.Name · @a.ScenarioId · @FormatDueAtCst(a.DueAtUtc)</option>
                    }
                </select>
            }

            <div class="divider"></div>
            <div class="sectionTitle">Grade Students</div>

            @if (_selectedClass.Students.Count == 0)
            {
                <div class="warningMessage">This class has no students.</div>
            }
            else
            {
                <div class="gradeList">
                    @foreach (var email in _selectedClass.Students.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
                    {
                        var submission = GetSubmissionForStudent(email);
                        var hasSubmission = submission?.SubmittedAtUtc is not null;

                        <div class="gradeCard">
                            <div class="gradeStudentRow">
                                <div class="classMgmtStudentEmail">@email</div>
                                @if (hasSubmission)
                                {
                                    <button class="gradeStatus done"
                                            type="button"
                                            @onclick="() => OpenSubmission(email)">
                                        @($"Submitted {submission!.SubmittedAtUtc!.Value.ToLocalTime():g}")
                                    </button>
                                }
                                else
                                {
                                    <div class="gradeStatus pending">Not submitted</div>
                                }
                            </div>

                            <div class="gradeInputRow">
                                <div>
                                    <label class="editorLabel">Grade (0-100)</label>
                                    <input class="editorInput"
                                           type="number"
                                           min="0"
                                           max="100"
                                           step="0.1"
                                           value="@GetGradeInput(email)"
                                           @oninput="(e) => SetGradeInput(email, e)" />
                                </div>
                                <div>
                                    <label class="editorLabel">Feedback</label>
                                    <textarea rows="3"
                                              @bind="@_feedbackInputs[email]"
                                              @bind:event="oninput"
                                              placeholder="Optional feedback to student"></textarea>
                                </div>
                            </div>

                            <button class="primaryBtn" @onclick="() => SaveGradeAsync(email)" disabled="@_isSavingGrade">Save grade</button>
                        </div>
                    }
                </div>
            }
        </div>
        }
    }
</div>

@code {
    [Parameter] public string ClassId { get; set; } = "";
    [Parameter] public string AssignmentId { get; set; } = "";

    private bool _isLoading = true;
    private bool _isAdmin;
    private bool _isSavingGrade;

    private string _message = "";
    private string _messageKind = "success";
    private int _messageVersion;
    private string _errorMessage = "";
    private string _headerSubtitle = "Grade student submissions for this assignment";

    private ClassRosterDto? _selectedClass;
    private ClassAssignmentDto? _selectedAssignment;
    private List<ClassAssignmentDto> _assignments = new();
    private string? _activeSubmissionEmail;

    private readonly Dictionary<string, string> _gradeInputs = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _feedbackInputs = new(StringComparer.OrdinalIgnoreCase);
    private static readonly TimeSpan CstOffset = TimeSpan.FromHours(-6);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var access = await Api.GetAccessAsync();
            _isAdmin = access?.IsAdmin == true;

            if (!_isAdmin)
            {
                return;
            }

            await LoadClassAndAssignmentAsync();
        }
        catch
        {
            _errorMessage = "Could not load grading data.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadClassAndAssignmentAsync()
    {
        var classes = await Api.Http.GetFromJsonAsync<List<ClassRosterDto>>("api/classes") ?? new List<ClassRosterDto>();
        _selectedClass = classes.FirstOrDefault(x => x.Id == ClassId);

        if (_selectedClass is null)
        {
            _errorMessage = "Class not found.";
            return;
        }

        _assignments = await Api.Http.GetFromJsonAsync<List<ClassAssignmentDto>>($"api/classes/{_selectedClass.Id}/assignments") ?? new List<ClassAssignmentDto>();
        _selectedAssignment = _assignments.FirstOrDefault(x => x.Id == AssignmentId);

        if (_selectedAssignment is null)
        {
            _errorMessage = "Assignment not found for this class.";
            return;
        }

        _headerSubtitle = $"{_selectedClass.Name} · {_selectedAssignment.Name}";
        SeedGradeInputs();
    }

    private void OnAssignmentChanged(ChangeEventArgs e)
    {
        var selectedId = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(selectedId) || _selectedClass is null)
        {
            return;
        }

        Nav.NavigateTo($"assignment-grading/{_selectedClass.Id}/{selectedId}");
    }

    private void SeedGradeInputs()
    {
        _gradeInputs.Clear();
        _feedbackInputs.Clear();
        _activeSubmissionEmail = null;

        if (_selectedClass is null)
        {
            return;
        }

        foreach (var email in _selectedClass.Students)
        {
            var submission = GetSubmissionForStudent(email);
            _gradeInputs[email] = submission?.Grade?.ToString("0.##") ?? "";
            _feedbackInputs[email] = submission?.GradeFeedback ?? "";
        }
    }

    private void OpenSubmission(string email)
    {
        _activeSubmissionEmail = email;
    }

    private AssignmentSubmissionDto? GetSubmissionForStudent(string email)
    {
        return _selectedAssignment?.Submissions.FirstOrDefault(x => string.Equals(x.StudentEmail, email, StringComparison.OrdinalIgnoreCase));
    }

    private string GetGradeInput(string email)
    {
        if (_gradeInputs.TryGetValue(email, out var value))
        {
            return value;
        }

        _gradeInputs[email] = "";
        return "";
    }

    private void SetGradeInput(string email, ChangeEventArgs e)
    {
        _gradeInputs[email] = (e.Value?.ToString() ?? "").Trim();
    }

    private async Task SaveGradeAsync(string studentEmail)
    {
        await SaveGradeCoreAsync(studentEmail, reloadAfterSave: true);
    }

    private async Task SaveAndBackSubmissionAsync(string studentEmail)
    {
        var ok = await SaveGradeCoreAsync(studentEmail, reloadAfterSave: true);
        if (ok)
        {
            _activeSubmissionEmail = null;
        }
    }

    private async Task<bool> SaveGradeCoreAsync(string studentEmail, bool reloadAfterSave)
    {
        if (_selectedClass is null || _selectedAssignment is null)
        {
            SetMessage("Assignment not loaded", false);
            return false;
        }

        var gradeText = GetGradeInput(studentEmail);
        decimal? grade = null;

        if (!string.IsNullOrWhiteSpace(gradeText))
        {
            if (!decimal.TryParse(gradeText, out var parsed))
            {
                SetMessage("Grade must be a number", false);
                return false;
            }

            if (parsed < 0m || parsed > 100m)
            {
                SetMessage("Grade must be between 0 and 100", false);
                return false;
            }

            grade = parsed;
        }

        _isSavingGrade = true;

        try
        {
            var feedback = _feedbackInputs.TryGetValue(studentEmail, out var f) ? f : "";

            var resp = await Api.Http.PutAsJsonAsync(
                $"api/classes/{_selectedClass.Id}/assignments/{_selectedAssignment.Id}/grades",
                new GradeAssignmentRequest
                {
                    StudentEmail = studentEmail,
                    Grade = grade,
                    Feedback = feedback
                });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Save grade failed {((int)resp.StatusCode)} {body}", false);
                return false;
            }

            SetMessage("Grade saved", true);
            if (reloadAfterSave)
            {
                await LoadClassAndAssignmentAsync();
            }
            return true;
        }
        catch
        {
            SetMessage("Could not save grade", false);
            return false;
        }
        finally
        {
            _isSavingGrade = false;
        }
    }

    private void SetMessage(string text, bool ok)
    {
        _message = text;
        _messageKind = ok ? "success" : "error";
        var version = ++_messageVersion;
        _ = ClearMessageLater(version);
    }

    private async Task ClearMessageLater(int version)
    {
        await Task.Delay(3000);
        if (version != _messageVersion)
        {
            return;
        }

        _message = "";
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatDueAtCst(DateTimeOffset? dueAtUtc)
    {
        if (!dueAtUtc.HasValue)
        {
            return "No due date";
        }

        return $"{dueAtUtc.Value.ToOffset(CstOffset).ToString("MM/dd/yyyy h:mm tt", CultureInfo.InvariantCulture)} CST";
    }

    private sealed class ClassRosterDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public List<string> Students { get; set; } = new();
    }

    private sealed class AssignmentSubmissionDto
    {
        public string StudentEmail { get; set; } = "";
        public DateTimeOffset? SubmittedAtUtc { get; set; }
        public string SubmissionText { get; set; } = "";
        public decimal? Grade { get; set; }
        public string GradeFeedback { get; set; } = "";
        public DateTimeOffset? GradedAtUtc { get; set; }
        public string GradedByEmail { get; set; } = "";
    }

    private sealed class ClassAssignmentDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string ScenarioId { get; set; } = "";
        public DateTimeOffset AssignedAtUtc { get; set; }
        public DateTimeOffset? DueAtUtc { get; set; }
        public List<AssignmentSubmissionDto> Submissions { get; set; } = new();
    }

    private sealed class GradeAssignmentRequest
    {
        public string StudentEmail { get; set; } = "";
        public decimal? Grade { get; set; }
        public string Feedback { get; set; } = "";
    }
}
