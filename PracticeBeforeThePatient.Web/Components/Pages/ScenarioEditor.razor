@page "/scenario-editor"
@rendermode InteractiveServer

<PageTitle>Scenario Editor</PageTitle>

@if (!string.IsNullOrWhiteSpace(_saveMessage))
{
    <div @key="_saveMessageVersion" class="saveMessage overlayToast @(_saveSuccess ? "success" : "error")" role="status" aria-live="polite">
        @_saveMessage
    </div>
}

<div class="simShell">

    @if (_isLoadingAccess)
    {
        <div class="card">
            <div class="sectionTitle">Loading</div>
            <div class="narrLine">Checking access</div>
        </div>
    }
    else if (!_isTeacher)
    {
        <div class="card">
            <div class="sectionTitle">Not available</div>
            <div class="narrLine">This page is only available to instructors and admins</div>
        </div>
    }
    else if (_isLoading)
    {
        <div class="card">
            <div class="sectionTitle">Loading</div>
            <div class="narrLine">Fetching scenarios from the API...</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="card">
            <div class="sectionTitle">Error</div>
            <div class="narrLine">@_errorMessage</div>
        </div>
    }
    else
    {
        <div class="simHeaderRow">
            <div class="simHeaderText">
                <div class="simBadge">Instructor Tools</div>
                <div class="simTitle">Scenario Editor</div>
                <div class="simSubtitle">Generate a scenario, then refine the branching flow before assigning it</div>
            </div>

            <div class="scenarioBar">
                <select class="scenarioInlineSelect"
                        @bind="SelectedScenarioId"
                        @bind:after="OnScenarioChanged"
                        disabled="@_isLoadingScenario">
                    <option value="">-- Select Scenario --</option>
                    @foreach (var id in AvailableScenarioIds)
                    {
                        <option value="@id">@id</option>
                    }
                </select>
            </div>
        </div>

        <div class="simGridSingle">
            <div class="card generatorCard">
                <div class="generatorTop">
                    <div>
                        <div class="generatorBadge">AI</div>
                        <div class="sectionTitle generatorTitle">Generate a new scenario</div>
                        <div class="generatorSubtitle">
                            Create a branching clinical case, save it immediately, then edit any node below.
                        </div>
                    </div>
                </div>

                <div class="generatorGrid">
                    <div class="generatorField generatorFieldWide">
                        <label class="editorLabel" for="generate-topic">Topic</label>
                        <textarea id="generate-topic"
                                  class="editorTextarea generatorTextarea"
                                  rows="3"
                                  placeholder="Example: Acute lateral ankle sprain during return-to-play evaluation"
                                  @bind="GenerateTopic"></textarea>
                    </div>

                    <div class="generatorField">
                        <label class="editorLabel" for="generate-scenario-id">Scenario Id</label>
                        <input id="generate-scenario-id"
                               type="text"
                               class="editorInput"
                               placeholder="Optional custom id"
                               @bind="GenerateScenarioId" />
                        <div class="generatorFieldHint">Letters, numbers, dashes, and underscores only.</div>
                    </div>

                    <div class="generatorField">
                        <label class="editorLabel" for="generate-max-depth">Branch depth</label>
                        <select id="generate-max-depth" class="editorInput" @bind="GenerateMaxDepth">
                            @for (var depth = 2; depth <= 5; depth++)
                            {
                                <option value="@depth">@depth @(depth == 1 ? "level" : "levels")</option>
                            }
                        </select>
                        <div class="generatorFieldHint">Use 2 to 5 levels. Higher depth creates a larger decision tree.</div>
                    </div>
                </div>

                <div class="generatorActions">
                    <button class="primaryBtn generatorActionBtn"
                            type="button"
                            @onclick="GenerateScenarioAsync"
                            disabled="@_isGenerating">
                        @(_isGenerating ? "Generating..." : "Generate Scenario")
                    </button>

                    <div class="generatorHint">
                        The generated scenario is saved automatically and loaded into the editor when the AI engine returns.
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_generationMessage))
                {
                    <div class="@GetGenerationMessageClass()" role="status" aria-live="polite">
                        @_generationMessage
                    </div>
                }
            </div>
        </div>

        @if (_scenario != null)
        {
            <div class="simGridSingle">
                <div class="card">
                    <div class="editorHeader">
                        <div class="sectionTitle">@_scenario.Title</div>
                        <button class="primaryBtn" @onclick="SaveScenario" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save Changes")
                        </button>
                    </div>

                    <div class="divider"></div>

                    <div class="scenarioTitleEditor">
                        <label class="editorLabel">Scenario Title</label>
                        <input type="text" class="editorInput" @bind="_scenario.Title" />
                    </div>

                    <div class="scenarioTitleEditor">
                        <label class="editorLabel">Scenario Description</label>
                        <textarea class="editorTextarea" rows="3" @bind="_scenario.Description"></textarea>
                    </div>

                    <div class="divider"></div>

                    <div class="nodesHeader">
                        <div class="sectionTitle">Scenario Nodes</div>
                        <div class="nodeHeaderActions">
                            <button type="button" class="secondaryBtn" @onclick="ExpandAll">Expand All</button>
                            <button type="button" class="secondaryBtn" @onclick="CollapseAll">Collapse All</button>
                        </div>
                    </div>

                    @if (_scenario.Root != null)
                    {
                        <CascadingValue Value="_nodeSelection">
                            <NodeEditor @ref="_rootNodeEditor" Node="_scenario.Root" Path="Root" Level="0" />
                        </CascadingValue>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="simGridSingle">
                <div class="card">
                    <div class="sectionTitle">No scenario selected</div>
                    <div class="narrLine">Generate a new scenario above or select an existing scenario to edit.</div>
                </div>
            </div>
        }
    }

</div>
