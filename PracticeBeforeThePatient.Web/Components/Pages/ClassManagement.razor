    private async Task CreateAssignmentAsync()
    {
        if (_selectedClass is null)
        {
            SetMessage("Select a class first", false);
            return;
        }

        var assignmentName = (_assignmentName ?? "").Trim();
        var assignmentScenarioId = (_assignmentScenarioId ?? "").Trim();
        var assignmentAssignDate = (_assignmentAssignDate ?? "").Trim();
        var assignmentAssignTime = string.IsNullOrWhiteSpace(assignmentAssignDate)
            ? ""
            : BuildTwelveHourTimeText(_assignmentAssignHour, _assignmentAssignMinute, _assignmentAssignPeriod);
        var assignmentDate = (_assignmentDate ?? "").Trim();
        var assignmentTime = string.IsNullOrWhiteSpace(assignmentDate)
            ? ""
            : BuildTwelveHourTimeText(_assignmentDueHour, _assignmentDueMinute, _assignmentDuePeriod);

        if (string.IsNullOrWhiteSpace(assignmentName))
        {
            SetMessage("Enter an assignment name", false);
            return;
        }

        if (string.IsNullOrWhiteSpace(assignmentScenarioId))
        {
            SetMessage("Select a scenario to assign", false);
            return;
        }

        if (!TryBuildOptionalCstDateTimeUtc(
            assignmentAssignDate,
            assignmentAssignTime,
            defaultTime: new TimeOnly(0, 0),
            missingDateMessage: "Select an assign date when entering an assign time",
            invalidDateMessage: "Invalid assign date",
            invalidTimeMessage: "Invalid assign time. Use h:mm AM/PM.",
            out var assignedAtUtc,
            out var assignError))
        {
            SetMessage(assignError, false);
            return;
        }

        if (!TryBuildOptionalCstDateTimeUtc(
            assignmentDate,
            assignmentTime,
            defaultTime: new TimeOnly(23, 59),
            missingDateMessage: "Select a due date when entering a due time",
            invalidDateMessage: "Invalid due date",
            invalidTimeMessage: "Invalid due time. Use h:mm AM/PM.",
            out var dueAtUtc,
            out var dueError))
        {
            SetMessage(dueError, false);
            return;
        }

        if (assignedAtUtc.HasValue && dueAtUtc.HasValue && dueAtUtc.Value < assignedAtUtc.Value)
        {
            SetMessage("Due date must be after the assign date", false);
            return;
        }

        try
        {
            var resp = await Api.Http.PostAsJsonAsync($"api/classes/{_selectedClass.Id}/assignments", new CreateAssignmentRequest
            {
                Name = assignmentName,
                ScenarioId = assignmentScenarioId,
                AssignedAtUtc = assignedAtUtc,
                DueAtUtc = dueAtUtc
            });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Assign failed {((int)resp.StatusCode)} {body}", false);

                return;
            }

            _assignmentName = "";
            _assignmentAssignDate = "";
            _assignmentAssignHour = "";
            _assignmentAssignMinute = "";
            _assignmentAssignPeriod = DefaultAssignPeriod;
            _assignmentDate = "";
            _assignmentDueHour = "";
            _assignmentDueMinute = "";
            _assignmentDuePeriod = DefaultDuePeriod;
            _isAddAssignmentModalOpen = false;
            SetMessage(assignedAtUtc.HasValue ? "Assignment scheduled" : "Scenario assigned", true);
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not create assignment", false);
        }
    }

    private void ToggleDueEditor(ClassAssignmentDto assignment)
    {
        if (_editingAssignmentDueId == assignment.Id)
        {
            CancelDueEditor();
            return;
        }

        _editingAssignmentDueId = assignment.Id;
        if (assignment.DueAtUtc.HasValue)
        {
            var dueCst = assignment.DueAtUtc.Value.ToOffset(CstOffset);
            _editDueDate = dueCst.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            _editDueHour = dueCst.ToString("%h", CultureInfo.InvariantCulture);
            _editDueMinute = dueCst.ToString("mm", CultureInfo.InvariantCulture);
            _editDuePeriod = dueCst.ToString("tt", CultureInfo.InvariantCulture);
        }
        else
        {
            _editDueDate = "";
            _editDueHour = "";
            _editDueMinute = "";
            _editDuePeriod = DefaultDuePeriod;
        }
    }

    private void CancelDueEditor()
    {
        _editingAssignmentDueId = null;
        _editDueDate = "";
        _editDueHour = "";
        _editDueMinute = "";
        _editDuePeriod = DefaultDuePeriod;
    }

    private async Task SaveAssignmentDueAsync(int assignmentId)
    {
        if (_selectedClass is null)
        {
            SetMessage("Select a class first", false);
            return;
        }

        var dueDateText = (_editDueDate ?? "").Trim();
        var dueTimeText = string.IsNullOrWhiteSpace(dueDateText)
            ? ""
            : BuildTwelveHourTimeText(_editDueHour, _editDueMinute, _editDuePeriod);
        var assignment = _assignments.FirstOrDefault(x => x.Id == assignmentId);

        if (!TryBuildOptionalCstDateTimeUtc(
            dueDateText,
            dueTimeText,
            defaultTime: new TimeOnly(23, 59),
            missingDateMessage: "Select a due date when entering a due time",
            invalidDateMessage: "Invalid due date",
            invalidTimeMessage: "Invalid due time. Use h:mm AM/PM.",
            out var dueAtUtc,
            out var dueError))
        {
            SetMessage(dueError, false);
            return;
        }

        if (assignment is not null && dueAtUtc.HasValue && dueAtUtc.Value < assignment.AssignedAtUtc)
        {
            SetMessage("Due date must be after the assign date", false);
            return;
        }

        _isSavingDue = true;
        try
        {
            var resp = await Api.Http.PutAsJsonAsync(
                $"api/classes/{_selectedClass.Id}/assignments/{assignmentId}/due",
                new UpdateAssignmentDueRequest
                {
                    DueAtUtc = dueAtUtc
                });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Update due failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            SetMessage("Due date updated", true);
            CancelDueEditor();
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not update due date", false);
        }
        finally
        {
            _isSavingDue = false;
        }
    }

    private async Task ClearAssignmentDueAsync(int assignmentId)
    {
        _editDueDate = "";
        _editDueHour = "";
        _editDueMinute = "";
        _editDuePeriod = DefaultDuePeriod;
        await SaveAssignmentDueAsync(assignmentId);
    }

    private static string FormatAssignedAtCst(DateTimeOffset assignedAtUtc)
    {
        return $"{assignedAtUtc.ToOffset(CstOffset).ToString("MM/dd/yyyy h:mm tt", CultureInfo.InvariantCulture)} CST";
    }

    private static string FormatDueAtCst(DateTimeOffset? dueAtUtc)
    {
        if (!dueAtUtc.HasValue)
        {
            return "No due date";
        }

        return $"{dueAtUtc.Value.ToOffset(CstOffset).ToString("MM/dd/yyyy h:mm tt", CultureInfo.InvariantCulture)} CST";
    }

    private static string BuildTwelveHourTimeText(string hour, string minute, string period)
    {
        var normalizedHour = int.TryParse(hour, out var parsedHour)
            ? Math.Clamp(parsedHour, 1, 12).ToString(CultureInfo.InvariantCulture)
            : DefaultDueHour;

        var normalizedMinute = int.TryParse(minute, out var parsedMinute)
            ? Math.Clamp(parsedMinute, 0, 59).ToString("00", CultureInfo.InvariantCulture)
            : DefaultDueMinute;

        var normalizedPeriod = string.Equals(period, "AM", StringComparison.OrdinalIgnoreCase) ? "AM" : "PM";
        return $"{normalizedHour}:{normalizedMinute} {normalizedPeriod}";
    }

    private static string NormalizeTimePartInput(string? rawValue)
    {
        var digitsOnly = new string((rawValue ?? "").Where(char.IsDigit).Take(2).ToArray());
        return digitsOnly;
    }

    private static bool TryBuildOptionalCstDateTimeUtc(
        string dateText,
        string timeText,
        TimeOnly defaultTime,
        string missingDateMessage,
        string invalidDateMessage,
        string invalidTimeMessage,
        out DateTimeOffset? valueUtc,
        out string error)
    {
        valueUtc = null;
        error = "";

        if (string.IsNullOrWhiteSpace(dateText) && string.IsNullOrWhiteSpace(timeText))
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(dateText))
        {
            error = missingDateMessage;
            return false;
        }

        if (!DateOnly.TryParse(dateText, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            error = invalidDateMessage;
            return false;
        }

        TimeOnly parsedTime;
        if (string.IsNullOrWhiteSpace(timeText))
        {
            parsedTime = defaultTime;
        }
        else if (!TryParseTwelveHourTime(timeText, out parsedTime))
        {
            error = invalidTimeMessage;
            return false;
        }

        var valueCst = new DateTimeOffset(parsedDate.ToDateTime(parsedTime), CstOffset);
        valueUtc = valueCst.ToUniversalTime();
        return true;
    }

    private static bool TryParseTwelveHourTime(string input, out TimeOnly time)
    {
        var value = (input ?? "").Trim();
        var formats = new[] { "h:mm tt", "hh:mm tt", "h:mmtt", "hh:mmtt" };
        return TimeOnly.TryParseExact(value, formats, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out time);
    }

