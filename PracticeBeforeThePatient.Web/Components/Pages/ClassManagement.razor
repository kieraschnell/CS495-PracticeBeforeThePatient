@page "/class-management"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Globalization
@using PracticeBeforeThePatient.Web.Services
@inject ApiClient Api

<PageTitle>Class Management</PageTitle>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div @key="_messageVersion" class="saveMessage overlayToast @_messageKind" role="status" aria-live="polite">
        @_message
    </div>
}

@if (!_isTeacherLoaded)
{
    <div class="card">
        <div class="sectionTitle">Loading</div>
        <div class="narrLine">Checking access</div>
    </div>
    return;
}

@if (!_isTeacher)
{
    <div class="card">
        <div class="sectionTitle">Not available</div>
        <div class="narrLine">This page is only available to teachers and admins</div>
    </div>
    return;
}

<div class="simShell">
    <div class="simHeaderRow">
        <div class="simHeaderText">
            <div class="simBadge">Teacher</div>
            <div class="simTitle">Class Management</div>
            <div class="simSubtitle">Create classes, assign scenarios, and open grading pages</div>
        </div>
        <button class="primaryBtn" type="button" @onclick="OpenAddClassModal">Add class</button>
    </div>

    <div class="card" @onclick="CloseMenu">
        <div class="sectionTitle">Classes</div>

        <div class="editArea">
            <div class="editTopRow">
                <div class="editSelect">
                    <label class="editorLabel">Select a class</label>
                    <select class="editorInput" value="@_selectedClassId" @onchange="OnSelectedClassChanged">
                        <option value="">Select</option>
                        @foreach (var c in _classes)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="kebabWrap" @onclick:stopPropagation="true">
                    <button class="kebabBtn" @onclick="ToggleMenu" disabled="@string.IsNullOrWhiteSpace(_selectedClassId)">&#8942;</button>

                    @if (_menuOpen && !string.IsNullOrWhiteSpace(_selectedClassId))
                    {
                        <div class="kebabMenu">
                            <button class="kebabMenuItem danger" @onclick="DeleteSelectedClassAsync">Delete class</button>
                        </div>
                    }
                </div>
            </div>

            @if (_selectedClass is not null)
            {
                <div class="divider"></div>

                <div class="assignmentTopRow">
                    <div class="sectionTitle">Assignments</div>
                    <button class="secondaryBtn" type="button" @onclick="OpenAddAssignmentModalAsync">Add assignment</button>
                </div>

                @if (_assignments.Count == 0)
                {
                    <div class="infoMessage">No assignments yet for this class</div>
                }
                else
                {
                    <div class="assignmentList">
                        @foreach (var a in _assignments)
                        {
                            var submitted = a.Submissions.Count(x => x.SubmittedAtUtc.HasValue);
                            var total = _selectedClass.Students.Count;
                            <div class="assignmentItem">
                                <div class="assignmentInfo">
                                    <div class="assignmentTitle">@a.Name</div>
                                    <div class="assignmentMeta">Scenario: @a.ScenarioId</div>
                                    <div class="assignmentMeta">
                                        Due: @FormatDueAtCst(a.DueAtUtc)
                                    </div>
                                    <div class="assignmentMeta">Submitted: @submitted / @total</div>
                                </div>
                                <div class="assignmentActions">
                                    <button class="secondaryBtn" type="button" @onclick="() => ToggleDueEditor(a)">Edit due</button>
                                    <a class="secondaryBtn" href="@($"assignment-grading/{_selectedClass.Id}/{a.Id}")">Grade</a>
                                    <button class="deleteBtn" @onclick="() => DeleteAssignmentAsync(a.Id)">Delete</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="divider"></div>

                <div class="sectionTitle">Manage Students</div>

                <div class="classMgmtAddRow">
                    <div class="classMgmtAddInput">
                        <label class="editorLabel">Student email</label>
                        <input class="editorInput" value="@_emailToAdd" @oninput="OnEmailInput" @onkeydown="OnAddStudentKeyDown" placeholder="student@ua.edu" />
                    </div>

                    <div class="classMgmtAddBtn">
                        <label class="editorLabel">&nbsp;</label>
                        <button class="primaryBtn" @onclick="AddStudentAsync" disabled="@string.IsNullOrWhiteSpace(_emailToAdd)">Add student</button>
                    </div>
                </div>

                <div class="divider"></div>

                <div class="classMgmtRosterHeader">
                    <div class="panel-title">Roster</div>
                    <div class="classMgmtCount">@_selectedClass!.Students.Count student(s)</div>
                </div>

                @if (_selectedClass!.Students.Count == 0)
                {
                    <div class="infoMessage">No students yet, add one using the email field above</div>
                }
                else
                {
                    <div class="classMgmtRoster">
                        @foreach (var email in _selectedClass!.Students.OrderBy(x => x))
                        {
                            <div class="classMgmtStudent">
                                <div class="classMgmtStudentEmail">@email</div>
                                <button class="deleteBtn" @onclick="() => RemoveStudentAsync(email)">Remove</button>
                            </div>
                        }
                    </div>
                }
            }
            </div>
        </div>
    </div>

@if (_isAddClassModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddClassModal">
        <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add class</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddClassModal">Cancel</button>
            </div>

            <div class="createArea">
                <label class="editorLabel">Class name</label>
                <div class="createRow">
                    <input class="editorInput"
                           value="@_newClassName"
                           @oninput="OnNewClassNameInput"
                           @onkeydown="OnNewClassNameKeyDown"
                           placeholder="Example, AT 301 Lab Section A" />
                    <button class="primaryBtn" type="button" @onclick="CreateClassAsync" disabled="@string.IsNullOrWhiteSpace(_newClassName)">Create</button>
                </div>
                <div class="createHint">Class names must be unique</div>
            </div>
        </div>
    </div>
}

@if (_selectedClass is not null && _isAddAssignmentModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddAssignmentModal">
        <div class="classMgmtModalCard" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add assignment</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddAssignmentModal">Cancel</button>
            </div>

            @if (_isLoadingScenarios)
            {
                <div class="infoMessage">Loading scenarios</div>
            }
            else if (_allScenarioIds.Count == 0)
            {
                <div class="warningMessage">No scenarios found in the API</div>
            }
            else
            {
                <div class="assignmentModalForm">
                    <div>
                        <label class="editorLabel">Assignment name</label>
                        <input class="editorInput"
                               type="text"
                               @bind="_assignmentName"
                               @bind:event="oninput"
                               placeholder="Example: Week 4 Chest Pain Case" />
                    </div>
                    <div>
                        <label class="editorLabel">Scenario</label>
                        <select class="editorInput" @bind="_assignmentScenarioId">
                            <option value="">Select</option>
                            @foreach (var id in _allScenarioIds)
                            {
                                <option value="@id">@id</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="editorLabel">Due date (optional)</label>
                        <input class="editorInput"
                               type="date"
                               value="@_assignmentDate"
                               @onchange="OnAssignmentDateChanged" />
                    </div>
                    <div>
                        <label class="editorLabel">Due time (optional)</label>
                        <input class="editorInput"
                               type="text"
                               value="@_assignmentTime"
                               @onchange="OnAssignmentTimeChanged"
                               placeholder="h:mm AM/PM" />
                    </div>
                </div>

                <div class="assignmentModalActions">
                    <button class="primaryBtn" type="button" @onclick="CreateAssignmentAsync" disabled="@(!CanAssignScenario)">Assign scenario</button>
                </div>
            }
        </div>
    </div>
}

@if (_selectedClass is not null && !string.IsNullOrWhiteSpace(_editingAssignmentDueId))
{
    var editingAssignment = _assignments.FirstOrDefault(x => string.Equals(x.Id, _editingAssignmentDueId, StringComparison.Ordinal));
    if (editingAssignment is not null)
    {
        <div class="classMgmtModalBackdrop" @onclick="CancelDueEditor">
            <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
                <div class="classMgmtModalTop">
                    <div class="sectionTitle">Edit due date</div>
                    <button class="secondaryBtn" type="button" @onclick="CancelDueEditor" disabled="@_isSavingDue">Cancel</button>
                </div>

                <div class="assignmentMeta">@editingAssignment.Name · @editingAssignment.ScenarioId</div>

                <div class="assignmentModalForm assignmentModalFormSingle">
                    <div>
                        <label class="editorLabel">Due date (optional)</label>
                        <input class="editorInput"
                               type="date"
                               value="@_editDueDate"
                               @onchange="OnEditDueDateChanged" />
                    </div>
                    <div>
                        <label class="editorLabel">Due time (optional)</label>
                        <input class="editorInput"
                               type="text"
                               value="@_editDueTime"
                               @onchange="OnEditDueTimeChanged"
                               placeholder="h:mm AM/PM" />
                    </div>
                </div>

                <div class="assignmentModalActions assignmentDueModalActions">
                    <button class="primaryBtn"
                            type="button"
                            @onclick="() => SaveAssignmentDueAsync(editingAssignment.Id)"
                            disabled="@_isSavingDue">
                        Save due
                    </button>
                    <button class="secondaryBtn"
                            type="button"
                            @onclick="() => ClearAssignmentDueAsync(editingAssignment.Id)"
                            disabled="@_isSavingDue">
                        Clear due
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<ClassRosterDto> _classes = new();
    private string _newClassName = "";
    private bool _isAddClassModalOpen;
    private string _selectedClassId = "";
    private ClassRosterDto? _selectedClass;
    private string _emailToAdd = "";

    private string _message = "";
    private string _messageKind = "success";
    private int _messageVersion;

    private bool _menuOpen;

    private bool _isLoadingScenarios;
    private List<string> _allScenarioIds = new();

    private List<ClassAssignmentDto> _assignments = new();
    private bool _isAddAssignmentModalOpen;
    private string _assignmentName = "";
    private string _assignmentScenarioId = "";
    private string _assignmentDate = "";
    private string _assignmentTime = "";
    private string? _editingAssignmentDueId;
    private string _editDueDate = "";
    private string _editDueTime = "";
    private bool _isSavingDue;
    private static readonly TimeSpan CstOffset = TimeSpan.FromHours(-6);
    private bool CanAssignScenario =>
        !string.IsNullOrWhiteSpace(_assignmentName) &&
        !string.IsNullOrWhiteSpace(_assignmentScenarioId);

    private bool _isTeacherLoaded;
    private bool _isTeacher;

    protected override async Task OnInitializedAsync()
    {
        var access = await Api.GetAccessAsync();
        _isTeacher = access?.IsTeacher == true;
        _isTeacherLoaded = true;

        if (_isTeacher)
        {
            await ReloadClassesAsync();
            if (_classes.Count > 0)
            {
                _selectedClassId = _classes[0].Id;
                _selectedClass = _classes[0];
                await ReloadAvailableScenariosAsync();
                await ReloadAssignmentsAsync();
            }
        }
    }

    private void OpenAddClassModal()
    {
        _isAddClassModalOpen = true;
        _isAddAssignmentModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddClassModal()
    {
        _isAddClassModalOpen = false;
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }

    private async Task OpenAddAssignmentModalAsync()
    {
        if (_selectedClass is null)
        {
            return;
        }

        await ReloadAvailableScenariosAsync();
        _isAddAssignmentModalOpen = true;
        _isAddClassModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddAssignmentModal()
    {
        _isAddAssignmentModalOpen = false;
    }

    private void SetMessage(string text, bool ok)
    {
        _message = text;
        _messageKind = ok ? "success" : "error";
        StateHasChanged();
        var version = ++_messageVersion;
        _ = ClearMessageLater(version);
    }

    private async Task ClearMessageLater(int version)
    {
        await Task.Delay(3000);
        if (version != _messageVersion)
        {
            return;
        }

        _message = "";
        await InvokeAsync(StateHasChanged);
    }

    private void OnNewClassNameInput(ChangeEventArgs e)
    {
        _newClassName = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnEmailInput(ChangeEventArgs e)
    {
        _emailToAdd = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnAssignmentDateChanged(ChangeEventArgs e)
    {
        _assignmentDate = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnAssignmentTimeChanged(ChangeEventArgs e)
    {
        _assignmentTime = (e.Value?.ToString() ?? "").Trim();
    }

    private async Task OnNewClassNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateClassAsync();
        }
    }

    private async Task OnAddStudentKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddStudentAsync();
        }
    }

    private async Task ReloadClassesAsync()
    {
        try
        {
            var data = await Api.Http.GetFromJsonAsync<List<ClassRosterDto>>("api/classes");
            _classes = data ?? new List<ClassRosterDto>();
            _selectedClass = _classes.FirstOrDefault(x => x.Id == _selectedClassId);
        }
        catch
        {
            _classes = new List<ClassRosterDto>();
            _selectedClass = null;
            SetMessage("Could not load classes from the API", false);
        }
    }

    private async Task ReloadAvailableScenariosAsync()
    {
        if (_selectedClass is null)
        {
            _allScenarioIds = new List<string>();
            return;
        }

        _isLoadingScenarios = true;

        try
        {
            var all = await Api.Http.GetFromJsonAsync<List<string>>("api/scenarios");
            _allScenarioIds = (all ?? new List<string>())
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (string.IsNullOrWhiteSpace(_assignmentScenarioId) && _allScenarioIds.Count > 0)
            {
                _assignmentScenarioId = _allScenarioIds[0];
            }
        }
        catch
        {
            _allScenarioIds = new List<string>();
            SetMessage("Could not load scenarios from the API", false);
        }
        finally
        {
            _isLoadingScenarios = false;
        }
    }

    private async Task ReloadAssignmentsAsync()
    {
        if (_selectedClass is null)
        {
            ResetAssignmentState();
            return;
        }

        try
        {
            var assignments = await Api.Http.GetFromJsonAsync<List<ClassAssignmentDto>>($"api/classes/{_selectedClass.Id}/assignments");
            _assignments = (assignments ?? new List<ClassAssignmentDto>())
                .OrderBy(x => x.DueAtUtc ?? DateTimeOffset.MaxValue)
                .ThenBy(x => x.ScenarioId, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch
        {
            ResetAssignmentState();
            SetMessage("Could not load assignments from the API", false);
        }
    }

    private void ResetAssignmentState()
    {
        _assignments = new List<ClassAssignmentDto>();
        _assignmentName = "";
        _assignmentScenarioId = "";
        _assignmentDate = "";
        _assignmentTime = "";
        _isAddAssignmentModalOpen = false;
        CancelDueEditor();
    }

    private async Task CreateAssignmentAsync()
    {
        if (_selectedClass is null)
        {
            SetMessage("Select a class first", false);
            return;
        }

        var assignmentName = (_assignmentName ?? "").Trim();
        var assignmentScenarioId = (_assignmentScenarioId ?? "").Trim();
        var assignmentDate = (_assignmentDate ?? "").Trim();
        var assignmentTime = (_assignmentTime ?? "").Trim();

        if (string.IsNullOrWhiteSpace(assignmentName))
        {
            SetMessage("Enter an assignment name", false);
            return;
        }

        if (string.IsNullOrWhiteSpace(assignmentScenarioId))
        {
            SetMessage("Select a scenario to assign", false);
            return;
        }

        if (!TryBuildDueAtUtc(assignmentDate, assignmentTime, out var dueAtUtc, out var dueError))
        {
            SetMessage(dueError, false);
            return;
        }

        try
        {
            var resp = await Api.Http.PostAsJsonAsync($"api/classes/{_selectedClass.Id}/assignments", new CreateAssignmentRequest
            {
                Name = assignmentName,
                ScenarioId = assignmentScenarioId,
                DueAtUtc = dueAtUtc
            });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Assign failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            _assignmentName = "";
            _assignmentDate = "";
            _assignmentTime = "";
            _isAddAssignmentModalOpen = false;
            SetMessage("Scenario assigned", true);
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not create assignment", false);
        }
    }

    private void ToggleDueEditor(ClassAssignmentDto assignment)
    {
        if (string.Equals(_editingAssignmentDueId, assignment.Id, StringComparison.Ordinal))
        {
            CancelDueEditor();
            return;
        }

        _editingAssignmentDueId = assignment.Id;
        if (assignment.DueAtUtc.HasValue)
        {
            var dueCst = assignment.DueAtUtc.Value.ToOffset(CstOffset);
            _editDueDate = dueCst.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            _editDueTime = dueCst.ToString("h:mm tt", CultureInfo.InvariantCulture);
        }
        else
        {
            _editDueDate = "";
            _editDueTime = "";
        }
    }

    private void CancelDueEditor()
    {
        _editingAssignmentDueId = null;
        _editDueDate = "";
        _editDueTime = "";
    }

    private void OnEditDueDateChanged(ChangeEventArgs e)
    {
        _editDueDate = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnEditDueTimeChanged(ChangeEventArgs e)
    {
        _editDueTime = (e.Value?.ToString() ?? "").Trim();
    }

    private async Task SaveAssignmentDueAsync(string assignmentId)
    {
        if (_selectedClass is null)
        {
            SetMessage("Select a class first", false);
            return;
        }

        var dueDateText = (_editDueDate ?? "").Trim();
        var dueTimeText = (_editDueTime ?? "").Trim();

        if (!TryBuildDueAtUtc(dueDateText, dueTimeText, out var dueAtUtc, out var dueError))
        {
            SetMessage(dueError, false);
            return;
        }

        _isSavingDue = true;
        try
        {
            var resp = await Api.Http.PutAsJsonAsync(
                $"api/classes/{_selectedClass.Id}/assignments/{assignmentId}/due",
                new UpdateAssignmentDueRequest
                {
                    DueAtUtc = dueAtUtc
                });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Update due failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            SetMessage("Due date updated", true);
            CancelDueEditor();
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not update due date", false);
        }
        finally
        {
            _isSavingDue = false;
        }
    }

    private async Task ClearAssignmentDueAsync(string assignmentId)
    {
        _editDueDate = "";
        _editDueTime = "";
        await SaveAssignmentDueAsync(assignmentId);
    }

    private static string FormatDueAtCst(DateTimeOffset? dueAtUtc)
    {
        if (!dueAtUtc.HasValue)
        {
            return "No due date";
        }

        return $"{dueAtUtc.Value.ToOffset(CstOffset).ToString("MM/dd/yyyy h:mm tt", CultureInfo.InvariantCulture)} CST";
    }

    private static bool TryBuildDueAtUtc(string dueDateText, string dueTimeText, out DateTimeOffset? dueAtUtc, out string error)
    {
        dueAtUtc = null;
        error = "";

        if (string.IsNullOrWhiteSpace(dueDateText) && string.IsNullOrWhiteSpace(dueTimeText))
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(dueDateText))
        {
            error = "Select a due date when entering a due time";
            return false;
        }

        if (!DateOnly.TryParse(dueDateText, CultureInfo.InvariantCulture, DateTimeStyles.None, out var dueDate))
        {
            error = "Invalid due date";
            return false;
        }

        TimeOnly dueTime;
        if (string.IsNullOrWhiteSpace(dueTimeText))
        {
            dueTime = new TimeOnly(23, 59);
        }
        else if (!TryParseTwelveHourTime(dueTimeText, out dueTime))
        {
            error = "Invalid due time. Use h:mm AM/PM.";
            return false;
        }

        var dueCst = new DateTimeOffset(dueDate.ToDateTime(dueTime), CstOffset);
        dueAtUtc = dueCst.ToUniversalTime();
        return true;
    }

    private static bool TryParseTwelveHourTime(string input, out TimeOnly time)
    {
        var value = (input ?? "").Trim();
        var formats = new[] { "h:mm tt", "hh:mm tt", "h:mmtt", "hh:mmtt" };
        return TimeOnly.TryParseExact(value, formats, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out time);
    }

    private async Task DeleteAssignmentAsync(string assignmentId)
    {
        if (_selectedClass is null) return;

        try
        {
            var resp = await Api.Http.DeleteAsync($"api/classes/{_selectedClass.Id}/assignments/{assignmentId}");
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Delete assignment failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            SetMessage("Assignment deleted", true);
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not delete assignment", false);
        }
    }

    private async Task CreateClassAsync()
    {
        var name = _newClassName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            SetMessage("Enter a class name", false);
            return;
        }

        try
        {
            var resp = await Api.Http.PostAsJsonAsync("api/classes", new CreateClassRequest { Name = name });

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Create failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            var created = await resp.Content.ReadFromJsonAsync<ClassRosterDto>();
            _newClassName = "";
            _isAddClassModalOpen = false;
            _selectedClassId = created?.Id ?? "";
            SetMessage("Class created", true);

            await ReloadClassesAsync();
            await ReloadAvailableScenariosAsync();
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not create class", false);
        }
    }

    private async Task DeleteSelectedClassAsync()
    {
        _menuOpen = false;

        if (string.IsNullOrWhiteSpace(_selectedClassId))
        {
            SetMessage("Select a class first", false);
            return;
        }

        try
        {
            var resp = await Api.Http.DeleteAsync($"api/classes/{_selectedClassId}");
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Delete failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            _selectedClassId = "";
            _selectedClass = null;
            _emailToAdd = "";
            _allScenarioIds = new List<string>();
            _isAddClassModalOpen = false;
            _isAddAssignmentModalOpen = false;
            ResetAssignmentState();

            SetMessage("Class deleted", true);

            await ReloadClassesAsync();
            if (_classes.Count > 0)
            {
                _selectedClassId = _classes[0].Id;
                _selectedClass = _classes[0];
                await ReloadAvailableScenariosAsync();
                await ReloadAssignmentsAsync();
            }
        }
        catch
        {
            SetMessage("Could not delete class", false);
        }
    }

    private async Task OnSelectedClassChanged(ChangeEventArgs e)
    {
        _selectedClassId = e.Value?.ToString() ?? "";
        _emailToAdd = "";
        _menuOpen = false;
        _isAddClassModalOpen = false;
        _isAddAssignmentModalOpen = false;
        CancelDueEditor();

        await ReloadClassesAsync();
        await ReloadAvailableScenariosAsync();
        await ReloadAssignmentsAsync();
    }

    private async Task AddStudentAsync()
    {
        if (_selectedClass is null)
        {
            SetMessage("Select a class first", false);
            return;
        }

        var email = _emailToAdd.Trim().ToLowerInvariant();
        if (!LooksLikeEmail(email))
        {
            SetMessage("Enter a valid email", false);
            return;
        }

        try
        {
            var resp = await Api.Http.PostAsJsonAsync($"api/classes/{_selectedClass.Id}/students", new StudentRequest { Email = email });
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Add failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            _emailToAdd = "";
            SetMessage("Student added", true);
            await ReloadClassesAsync();
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not add student", false);
        }
    }

    private async Task RemoveStudentAsync(string email)
    {
        if (_selectedClass is null) return;

        try
        {
            var req = new HttpRequestMessage(HttpMethod.Delete, $"api/classes/{_selectedClass.Id}/students")
            {
                Content = JsonContent.Create(new StudentRequest { Email = email })
            };

            var resp = await Api.Http.SendAsync(req);
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                SetMessage($"Remove failed {((int)resp.StatusCode)} {body}", false);
                return;
            }

            SetMessage("Student removed", true);
            await ReloadClassesAsync();
            await ReloadAssignmentsAsync();
        }
        catch
        {
            SetMessage("Could not remove student", false);
        }
    }

    private static bool LooksLikeEmail(string value)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(value);
            return string.Equals(addr.Address, value, StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }

