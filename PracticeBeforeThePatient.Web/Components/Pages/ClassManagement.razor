@page "/class-management"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Globalization
@using PracticeBeforeThePatient.Web.Services
@inject ApiClient Api

<PageTitle>Class Management</PageTitle>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div @key="_messageVersion" class="saveMessage overlayToast @_messageKind" role="status" aria-live="polite">
        @_message
    </div>
}

@if (!_isTeacherLoaded)
{
    <div class="card">
        <div class="sectionTitle">Loading</div>
        <div class="narrLine">Checking access</div>
    </div>
    return;
}

@if (!_isTeacher)
{
    <div class="card">
        <div class="sectionTitle">Not available</div>
        <div class="narrLine">This page is only available to teachers and admins</div>
    </div>
    return;
}

<div class="simShell">
    <div class="simHeaderRow">
        <div class="simHeaderText">
            <div class="simBadge">Teacher</div>
            <div class="simTitle">Class Management</div>
            <div class="simSubtitle">Create classes, assign scenarios, and open grading pages</div>
        </div>
        <button class="primaryBtn" type="button" @onclick="OpenAddClassModal">Add class</button>
    </div>

    <div class="card" @onclick="CloseMenu">
        <div class="sectionTitle">Classes</div>

        <div class="editArea">
            <div class="editTopRow">
                <div class="editSelect">
                    <label class="editorLabel">Select a class</label>
                    <select class="editorInput" value="@_selectedClassId" @onchange="OnSelectedClassChanged">
                        <option value="0">Select</option>
                        @foreach (var c in _classes)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="kebabWrap" @onclick:stopPropagation="true">
                    <button class="kebabBtn" @onclick="ToggleMenu" disabled="@(_selectedClassId == 0)">&#8942;</button>

                    @if (_menuOpen && _selectedClassId != 0)
                    {
                        <div class="kebabMenu">
                            <button class="kebabMenuItem danger" @onclick="DeleteSelectedClassAsync">Delete class</button>
                        </div>
                    }
                </div>
            </div>

            @if (_selectedClass is not null)
            {
                <div class="divider"></div>

                <div class="assignmentTopRow">
                    <div class="sectionTitle">Assignments</div>
                    <button class="secondaryBtn" type="button" @onclick="OpenAddAssignmentModalAsync">Add assignment</button>
                </div>

                @if (_assignments.Count == 0)
                {
                    <div class="infoMessage">No assignments yet for this class</div>
                }
                else
                {
                    <div class="assignmentList">
                        @foreach (var a in _assignments)
                        {
                            var submitted = a.Submissions.Count(x => x.SubmittedAtUtc.HasValue);
                            var total = _selectedClass.Students.Count;
                            <div class="assignmentItem">
                                <div class="assignmentInfo">
                                    <div class="assignmentTitle">@a.Name</div>
                                    <div class="assignmentMeta">Scenario: @a.ScenarioId</div>
                                    <div class="assignmentMeta">Assign at: @FormatAssignedAtCst(a.AssignedAtUtc)</div>
                                    <div class="assignmentMeta">
                                        Due: @FormatDueAtCst(a.DueAtUtc)
                                    </div>
                                    <div class="assignmentMeta">Submitted: @submitted / @total</div>
                                </div>
                                <div class="assignmentActions">
                                    <button class="secondaryBtn" type="button" @onclick="() => ToggleDueEditor(a)">Edit due</button>
                                    <a class="secondaryBtn" href="@($"assignment-grading/{_selectedClass.Id}/{a.Id}")">Grade</a>
                                    <button class="deleteBtn" @onclick="() => DeleteAssignmentAsync(a.Id)">Delete</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="divider"></div>

                <div class="assignmentTopRow">
                    <div class="sectionTitle">Manage Teachers</div>
                    <button class="secondaryBtn" type="button" @onclick="OpenAddTeacherModal">Add teacher</button>
                </div>

                <div class="divider"></div>

                <div class="classMgmtRosterHeader">
                    <div class="panel-title">Teachers</div>
                    <div class="classMgmtCount">@_selectedClass!.Teachers.Count teacher(s)</div>
                </div>

                @if (_selectedClass!.Teachers.Count == 0)
                {
                    <div class="infoMessage">No teachers yet</div>
                }
                else
                {
                    <div class="classMgmtRoster">
                        @foreach (var email in _selectedClass!.Teachers.OrderBy(x => x))
                        {
                            <div class="classMgmtStudent">
                                <div class="classMgmtStudentEmail">@email</div>
                                <button class="deleteBtn" @onclick="() => RemoveTeacherAsync(email)" disabled="@IsCurrentTeacher(email)">Remove</button>
                            </div>
                        }
                    </div>
                }

                <div class="divider"></div>

                <div class="assignmentTopRow">
                    <div class="sectionTitle">Manage Students</div>
                    <button class="secondaryBtn" type="button" @onclick="OpenAddStudentModal">Add student</button>
                </div>

                <div class="divider"></div>

                <div class="classMgmtRosterHeader">
                    <div class="panel-title">Roster</div>
                    <div class="classMgmtCount">@_selectedClass!.Students.Count student(s)</div>
                </div>

                @if (_selectedClass!.Students.Count == 0)
                {
                    <div class="infoMessage">No students yet</div>
                }
                else
                {
                    <div class="classMgmtRoster">
                        @foreach (var email in _selectedClass!.Students.OrderBy(x => x))
                        {
                            <div class="classMgmtStudent">
                                <div class="classMgmtStudentEmail">@email</div>
                                <button class="deleteBtn" @onclick="() => RemoveStudentAsync(email)">Remove</button>
                            </div>
                        }
                    </div>
                }
            }
            </div>
        </div>
    </div>

@if (_isAddClassModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddClassModal">
        <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add class</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddClassModal">Cancel</button>
            </div>

            <div class="createArea">
                <label class="editorLabel">Class name</label>
                <div class="createRow">
                    <input class="editorInput"
                           value="@_newClassName"
                           @oninput="OnNewClassNameInput"
                           @onkeydown="OnNewClassNameKeyDown"
                           placeholder="Example, AT 301 Lab Section A" />
                    <button class="primaryBtn" type="button" @onclick="CreateClassAsync" disabled="@string.IsNullOrWhiteSpace(_newClassName)">Create</button>
                </div>
                <div class="createHint">Class names must be unique</div>
            </div>
        </div>
    </div>
}

@if (_selectedClass is not null && _isAddTeacherModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddTeacherModal">
        <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add teacher</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddTeacherModal">Cancel</button>
            </div>

            <div class="createArea">
                <label class="editorLabel">Teacher email</label>
                <div class="createRow">
                    <input class="editorInput"
                           value="@_teacherEmailToAdd"
                           @oninput="OnTeacherEmailInput"
                           @onkeydown="OnAddTeacherKeyDown"
                           placeholder="teacher@ua.edu" />
                    <button class="primaryBtn" type="button" @onclick="AddTeacherAsync" disabled="@string.IsNullOrWhiteSpace(_teacherEmailToAdd)">Add</button>
                </div>
                <div class="createHint">Adds a teacher to this class only</div>
            </div>
        </div>
    </div>
}

@if (_selectedClass is not null && _isAddStudentModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddStudentModal">
        <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add student</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddStudentModal">Cancel</button>
            </div>

            <div class="createArea">
                <label class="editorLabel">Student email</label>
                <div class="createRow">
                    <input class="editorInput"
                           value="@_emailToAdd"
                           @oninput="OnEmailInput"
                           @onkeydown="OnAddStudentKeyDown"
                           placeholder="student@ua.edu" />
                    <button class="primaryBtn" type="button" @onclick="AddStudentAsync" disabled="@string.IsNullOrWhiteSpace(_emailToAdd)">Add</button>
                </div>
                <div class="createHint">Adds a student roster entry for this class</div>
            </div>
        </div>
    </div>
}

@if (_selectedClass is not null && _isAddAssignmentModalOpen)
{
    <div class="classMgmtModalBackdrop" @onclick="CloseAddAssignmentModal">
        <div class="classMgmtModalCard" @onclick:stopPropagation="true">
            <div class="classMgmtModalTop">
                <div class="sectionTitle">Add assignment</div>
                <button class="secondaryBtn" type="button" @onclick="CloseAddAssignmentModal">Cancel</button>
            </div>

            @if (_isLoadingScenarios)
            {
                <div class="infoMessage">Loading scenarios</div>
            }
            else
            {
                <div class="assignmentModalForm">
                    <div>
                        <label class="editorLabel">Assignment name</label>
                        <input class="editorInput"
                               type="text"
                               @bind="_assignmentName"
                               @bind:event="oninput"
                               placeholder="Example: Week 4 Chest Pain Case" />
                    </div>
                    <div>
                        <label class="editorLabel">Scenario</label>
                        <select class="editorInput" @bind="_assignmentScenarioId">
                            <option value="">Select</option>
                            @foreach (var id in _allScenarioIds)
                            {
                                <option value="@id">@id</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="editorLabel">Assign date (optional)</label>
                        <input class="editorInput"
                               type="date"
                               value="@_assignmentAssignDate"
                               @onchange="OnAssignmentAssignDateChanged" />
                    </div>
                    <div>
                        <label class="editorLabel">Assign time (optional)</label>
                        <div style="display:flex; gap:10px; align-items:center; flex-wrap:nowrap;">
                            <input class="editorInput timeNumberInput"
                                   style="flex:0 0 5.5rem; min-width:5.5rem; width:5.5rem;"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_assignmentAssignDate)"
                                   value="@_assignmentAssignHour"
                                   @oninput="OnAssignmentAssignHourChanged" />
                            <span class="timeSeparator">:</span>
                            <input class="editorInput timeNumberInput"
                                   style="flex:0 0 5.5rem; min-width:5.5rem; width:5.5rem;"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_assignmentAssignDate)"
                                   value="@_assignmentAssignMinute"
                                   @oninput="OnAssignmentAssignMinuteChanged" />
                            <select class="editorInput timePeriodInput"
                                    style="flex:0 0 5.5rem; min-width:5.5rem; width:5.5rem;"
                                    disabled="@string.IsNullOrWhiteSpace(_assignmentAssignDate)"
                                    @bind="_assignmentAssignPeriod">
                                @foreach (var period in MeridiemOptions)
                                {
                                    <option value="@period">@period</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="editorLabel">Due date (optional)</label>
                        <input class="editorInput"
                               type="date"
                               value="@_assignmentDate"
                               @onchange="OnAssignmentDateChanged" />
                    </div>
                    <div>
                        <label class="editorLabel">Due time (optional)</label>
                        <div style="display:flex; gap:10px; align-items:center; flex-wrap:nowrap;">
                            <input class="editorInput timeNumberInput"
                                   style="flex:0 0 5.5rem; min-width:5.5rem; width:5.5rem;"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_assignmentDate)"
                                   value="@_assignmentDueHour"
                                   @oninput="OnAssignmentDueHourChanged" />
                            <span class="timeSeparator">:</span>
                            <input class="editorInput timeNumberInput"
                                   style="flex:0 0 5.5rem; min-width:5.5rem; width:5.5rem;"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_assignmentDate)"
                                   value="@_assignmentDueMinute"
                                   @oninput="OnAssignmentDueMinuteChanged" />
                            <select class="editorInput timePeriodInput"
                                    style="flex:0 0 6rem; min-width:6rem; width:6rem;"
                                    disabled="@string.IsNullOrWhiteSpace(_assignmentDate)"
                                    @bind="_assignmentDuePeriod">
                                @foreach (var period in MeridiemOptions)
                                {
                                    <option value="@period">@period</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="assignmentModalActions">
                    <button class="primaryBtn" type="button" @onclick="CreateAssignmentAsync">Assign scenario</button>
                </div>
            }
        </div>
    </div>
}

@if (_selectedClass is not null && _editingAssignmentDueId.HasValue)
{
    var editingAssignment = _assignments.FirstOrDefault(x => x.Id == _editingAssignmentDueId.Value);
    if (editingAssignment is not null)
    {
        <div class="classMgmtModalBackdrop" @onclick="CancelDueEditor">
            <div class="classMgmtModalCard classMgmtModalCardNarrow" @onclick:stopPropagation="true">
                <div class="classMgmtModalTop">
                    <div class="sectionTitle">Edit due date</div>
                    <button class="secondaryBtn" type="button" @onclick="CancelDueEditor" disabled="@_isSavingDue">Cancel</button>
                </div>

                <div class="assignmentMeta">@editingAssignment.Name · @editingAssignment.ScenarioId</div>

                <div class="assignmentModalForm assignmentModalFormSingle">
                    <div>
                        <label class="editorLabel">Due date (optional)</label>
                        <div class="dateTimeInputRow">
                            <input class="editorInput dateInputGrow"
                                   type="date"
                                   value="@_editDueDate"
                                   @onchange="OnEditDueDateChanged" />
                            <input class="editorInput timeNumberInput"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_editDueDate)"
                                   value="@_editDueHour"
                                   @oninput="OnEditDueHourChanged" />
                            <span class="timeSeparator">:</span>
                            <input class="editorInput timeNumberInput"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="2"
                                   disabled="@string.IsNullOrWhiteSpace(_editDueDate)"
                                   value="@_editDueMinute"
                                   @oninput="OnEditDueMinuteChanged" />
                            <select class="editorInput timePeriodInput"
                                    disabled="@string.IsNullOrWhiteSpace(_editDueDate)"
                                    @bind="_editDuePeriod">
                                @foreach (var period in MeridiemOptions)
                                {
                                    <option value="@period">@period</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="assignmentModalActions assignmentDueModalActions">
                    <button class="primaryBtn"
                            type="button"
                            @onclick="() => SaveAssignmentDueAsync(editingAssignment.Id)"
                            disabled="@_isSavingDue">
                        Save due
                    </button>
                    <button class="secondaryBtn"
                            type="button"
                            @onclick="() => ClearAssignmentDueAsync(editingAssignment.Id)"
                            disabled="@_isSavingDue">
                        Clear due
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<ClassRosterDto> _classes = new();
    private string _newClassName = "";
    private bool _isAddClassModalOpen;
    private bool _isAddTeacherModalOpen;
    private bool _isAddStudentModalOpen;
    private int _selectedClassId;
    private ClassRosterDto? _selectedClass;
    private string _emailToAdd = "";
    private string _teacherEmailToAdd = "";
    private string _currentEmail = "";

    private string _message = "";
    private string _messageKind = "success";
    private int _messageVersion;

    private bool _menuOpen;

    private bool _isLoadingScenarios;
    private List<string> _allScenarioIds = new();

    private List<ClassAssignmentDto> _assignments = new();
    private bool _isAddAssignmentModalOpen;
    private string _assignmentName = "";
    private string _assignmentScenarioId = "";
    private string _assignmentAssignDate = "";
    private string _assignmentAssignHour = "";
    private string _assignmentAssignMinute = "";
    private string _assignmentAssignPeriod = DefaultAssignPeriod;
    private string _assignmentDate = "";
    private string _assignmentDueHour = "";
    private string _assignmentDueMinute = "";
    private string _assignmentDuePeriod = DefaultDuePeriod;
    private int? _editingAssignmentDueId;
    private string _editDueDate = "";
    private string _editDueHour = "";
    private string _editDueMinute = "";
    private string _editDuePeriod = DefaultDuePeriod;
    private bool _isSavingDue;
    private static readonly TimeSpan CstOffset = TimeSpan.FromHours(-6);
    private const string DefaultAssignHour = "12";
    private const string DefaultAssignMinute = "00";
    private const string DefaultAssignPeriod = "AM";
    private const string DefaultDueHour = "11";
    private const string DefaultDueMinute = "59";
    private const string DefaultDuePeriod = "PM";
    private static readonly string[] MeridiemOptions = ["AM", "PM"];
    private bool _isTeacherLoaded;
    private bool _isTeacher;

    protected override async Task OnInitializedAsync()
    {
        var access = await Api.GetAccessAsync();
        _isTeacher = access?.IsTeacher == true;
        _currentEmail = (access?.Email ?? "").Trim().ToLowerInvariant();
        _isTeacherLoaded = true;

        if (_isTeacher)
        {
            await ReloadClassesAsync();
            if (_classes.Count > 0)
            {
                _selectedClassId = _classes[0].Id;
                _selectedClass = _classes[0];
                await ReloadAvailableScenariosAsync();
                await ReloadAssignmentsAsync();
            }
        }
    }

    private void OpenAddClassModal()
    {
        _isAddClassModalOpen = true;
        _isAddAssignmentModalOpen = false;
        _isAddTeacherModalOpen = false;
        _isAddStudentModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddClassModal()
    {
        _isAddClassModalOpen = false;
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }

    private async Task OpenAddAssignmentModalAsync()
    {
        if (_selectedClass is null)
        {
            return;
        }

        await ReloadAvailableScenariosAsync();
        _isAddAssignmentModalOpen = true;
        _isAddClassModalOpen = false;
        _isAddTeacherModalOpen = false;
        _isAddStudentModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddAssignmentModal()
    {
        _isAddAssignmentModalOpen = false;
    }

    private void OpenAddTeacherModal()
    {
        _teacherEmailToAdd = "";
        _isAddTeacherModalOpen = true;
        _isAddStudentModalOpen = false;
        _isAddAssignmentModalOpen = false;
        _isAddClassModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddTeacherModal()
    {
        _isAddTeacherModalOpen = false;
    }

    private void OpenAddStudentModal()
    {
        _emailToAdd = "";
        _isAddStudentModalOpen = true;
        _isAddTeacherModalOpen = false;
        _isAddAssignmentModalOpen = false;
        _isAddClassModalOpen = false;
        CancelDueEditor();
    }

    private void CloseAddStudentModal()
    {
        _isAddStudentModalOpen = false;
    }

    private void SetMessage(string text, bool ok)
    {
        _message = text;
        _messageKind = ok ? "success" : "error";
        StateHasChanged();
        var version = ++_messageVersion;
        _ = ClearMessageLater(version);
    }

    private async Task ClearMessageLater(int version)
    {
        await Task.Delay(3000);
        if (version != _messageVersion)
        {
            return;
        }

        _message = "";
        await InvokeAsync(StateHasChanged);
    }

    private void OnNewClassNameInput(ChangeEventArgs e)
    {
        _newClassName = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnEmailInput(ChangeEventArgs e)
    {
        _emailToAdd = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnTeacherEmailInput(ChangeEventArgs e)
    {
        _teacherEmailToAdd = (e.Value?.ToString() ?? "").Trim();
    }

    private void OnAssignmentDateChanged(ChangeEventArgs e)
    {
        _assignmentDate = (e.Value?.ToString() ?? "").Trim();
        if (string.IsNullOrWhiteSpace(_assignmentDate))
        {
            _assignmentDueHour = "";
            _assignmentDueMinute = "";
            _assignmentDuePeriod = DefaultDuePeriod;
            return;
        }

        if (string.IsNullOrWhiteSpace(_assignmentDueHour))
        {
            _assignmentDueHour = DefaultDueHour;
        }

        if (string.IsNullOrWhiteSpace(_assignmentDueMinute))
        {
            _assignmentDueMinute = DefaultDueMinute;
        }
    }

    private void OnAssignmentDueHourChanged(ChangeEventArgs e)
    {
        _assignmentDueHour = NormalizeTimePartInput(e.Value?.ToString());
    }

    private void OnAssignmentDueMinuteChanged(ChangeEventArgs e)
    {
        _assignmentDueMinute = NormalizeTimePartInput(e.Value?.ToString());
    }

    private void OnEditDueDateChanged(ChangeEventArgs e)
    {
        _editDueDate = (e.Value?.ToString() ?? "").Trim();
        if (string.IsNullOrWhiteSpace(_editDueDate))
        {
            _editDueHour = "";
            _editDueMinute = "";
            _editDuePeriod = DefaultDuePeriod;
            return;
        }

        if (string.IsNullOrWhiteSpace(_editDueHour))
        {
            _editDueHour = DefaultDueHour;
        }

        if (string.IsNullOrWhiteSpace(_editDueMinute))
        {
            _editDueMinute = DefaultDueMinute;
        }
    }

    private void OnEditDueHourChanged(ChangeEventArgs e)
    {
        _editDueHour = NormalizeTimePartInput(e.Value?.ToString());
    }

    private void OnEditDueMinuteChanged(ChangeEventArgs e)
    {
        _editDueMinute = NormalizeTimePartInput(e.Value?.ToString());
    }

    private void OnAssignmentAssignDateChanged(ChangeEventArgs e)
    {
        _assignmentAssignDate = (e.Value?.ToString() ?? "").Trim();
        if (string.IsNullOrWhiteSpace(_assignmentAssignDate))
        {
            _assignmentAssignHour = "";
            _assignmentAssignMinute = "";
            _assignmentAssignPeriod = DefaultAssignPeriod;
            return;
        }

        if (string.IsNullOrWhiteSpace(_assignmentAssignHour))
        {
            _assignmentAssignHour = DefaultAssignHour;
        }

        if (string.IsNullOrWhiteSpace(_assignmentAssignMinute))
        {
            _assignmentAssignMinute = DefaultAssignMinute;
        }
    }

    private void OnAssignmentAssignHourChanged(ChangeEventArgs e)
    {
        _assignmentAssignHour = NormalizeTimePartInput(e.Value?.ToString());
    }

    private void OnAssignmentAssignMinuteChanged(ChangeEventArgs e)
    {
        _assignmentAssignMinute = NormalizeTimePartInput(e.Value?.ToString());
    }

    private async Task OnNewClassNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateClassAsync();
        }
    }

    private async Task OnAddStudentKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddStudentAsync();
        }
    }

    private async Task OnAddTeacherKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddTeacherAsync();
        }
    }

    private async Task ReloadClassesAsync()
    {
        try
        {
            var data = await Api.Http.GetFromJsonAsync<List<ClassRosterDto>>("api/classes");
            _classes = data ?? new List<ClassRosterDto>();
            _selectedClass = _classes.FirstOrDefault(x => x.Id == _selectedClassId);
        }
        catch
        {
            _classes = new List<ClassRosterDto>();
            _selectedClass = null;
            SetMessage("Could not load classes from the API", false);
        }
    }

    private async Task ReloadAvailableScenariosAsync()
    {
        if (_selectedClass is null)
        {
            _allScenarioIds = new List<string>();
            return;
        }

        _isLoadingScenarios = true;

        try
        {
            var all = await Api.Http.GetFromJsonAsync<List<string>>("api/scenarios");
            _allScenarioIds = (all ?? new List<string>())
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (string.IsNullOrWhiteSpace(_assignmentScenarioId) && _allScenarioIds.Count > 0)
            {
                _assignmentScenarioId = _allScenarioIds[0];
            }
        }
        catch
        {
            _allScenarioIds = new List<string>();
            SetMessage("Could not load scenarios from the API", false);
        }
        finally
        {
            _isLoadingScenarios = false;
        }
    }

    private async Task ReloadAssignmentsAsync()
    {
        if (_selectedClass is null)
        {
            ResetAssignmentState();
            return;
        }

        try
        {
            var assignments = await Api.Http.GetFromJsonAsync<List<ClassAssignmentDto>>($"api/classes/{_selectedClass.Id}/assignments");
            _assignments = (assignments ?? new List<ClassAssignmentDto>())
                .OrderBy(x => x.AssignedAtUtc)
                .ThenBy(x => x.DueAtUtc ?? DateTimeOffset.MaxValue)
                .ThenBy(x => x.ScenarioId, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch
        {
            ResetAssignmentState();
            SetMessage("Could not load assignments from the API", false);
        }
    }

