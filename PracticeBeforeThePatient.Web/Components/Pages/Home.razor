@page "/"
@rendermode InteractiveServer
@using PracticeBeforeThePatient.Web.Services
@inject IJSRuntime JS
@inject AccessState AccessState

<PageTitle>Practice Before the Patient</PageTitle>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div @key="_messageVersion" class="saveMessage overlayToast @_messageKind" role="status" aria-live="polite">
        @_message
    </div>
}

<div class="home">

    <section class="hero">
        <div class="hero-content">
            <div class="hero-badge">Clinical Simulation Platform</div>

            <h1 class="hero-title">Practice Before the Patient</h1>

            <p class="hero-subtitle">
                Practice patient scenarios, explain your decisions, and review guided feedback in one place.
            </p>

            <div class="hero-actions">
                <a class="btn-primary" href="simulation">Start Simulation</a>
                <button class="homeThemeToggle" @onclick="ToggleThemeAsync" disabled="@(!_isReady)">
                    @(_isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode")
                </button>
            </div>
        </div>

        <div class="hero-panel">
            <div class="panel-card">
                <div class="panel-title">What you can do</div>

                <ul class="panel-list">
                    <li>Open a scenario and move through the encounter step by step</li>
                    <li>Record your reasoning before continuing to the next decision</li>
                    <li>Review patient responses and end-of-scenario feedback</li>
                </ul>

                <div class="panel-foot">
                    Student practice is available now. Class-linked saving and additional account features are still being completed.
                </div>
            </div>
        </div>

    </section>

    <section class="features">
        <div class="feature">
            <div class="feature-top">
                <div class="feature-icon"></div>
                <h3>Scenario Practice</h3>
            </div>
            <p>
                Work through guided patient encounters designed to help you slow down and think through each next step.
            </p>
        </div>

        <div class="feature">
            <div class="feature-top">
                <div class="feature-icon"></div>
                <h3>Reasoning Review</h3>
            </div>
            <p>
                Write out your reasoning, then compare your decisions with the recommended path at the end.
            </p>
        </div>

        <div class="feature">
            <div class="feature-top">
                <div class="feature-icon"></div>
                <h3>In Progress</h3>
            </div>
            <p>
                Some classroom and account-connected features are still being refined, but student practice mode is ready to use.
            </p>
        </div>
    </section>

</div>

@code {
    private bool _isReady;
    private bool _isDarkMode;
    private string _message = "";
    private string _messageKind = "success";
    private int _messageVersion;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var theme = NormalizeTheme(await JS.InvokeAsync<string>("pbpTheme.getTheme")) ?? "light";
        await JS.InvokeVoidAsync("pbpTheme.setTheme", theme);
        _isDarkMode = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
        _isReady = true;
        SyncAccessStateTheme(theme);

        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        var nextTheme = _isDarkMode ? "light" : "dark";
        var savedTheme = NormalizeTheme(await JS.InvokeAsync<string>("pbpTheme.setTheme", nextTheme)) ?? "light";
        _isDarkMode = string.Equals(savedTheme, "dark", StringComparison.OrdinalIgnoreCase);
        SyncAccessStateTheme(savedTheme);
        SetMessage("Theme preference saved on this device.", true);
    }

    private void SyncAccessStateTheme(string theme)
    {
        var current = AccessState.CurrentAccess;
        if (current is null)
        {
            return;
        }

        AccessState.Update(new ApiClient.AccessResponse
        {
            Email = current.Email,
            Role = current.Role,
            IsGuest = current.IsGuest,
            IsTeacher = current.IsTeacher,
            IsAdmin = current.IsAdmin,
            AllowedScenarioIds = current.AllowedScenarioIds,
            AllowedScenarioOptions = current.AllowedScenarioOptions,
            Theme = theme
        });
    }

    private static string? NormalizeTheme(string? theme)
    {
        if (string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase))
        {
            return "dark";
        }

        if (string.Equals(theme, "light", StringComparison.OrdinalIgnoreCase))
        {
            return "light";
        }

        return null;
    }

    private void SetMessage(string text, bool ok)
    {
        _message = text;
        _messageKind = ok ? "success" : "error";
        var version = ++_messageVersion;
        _ = ClearMessageLater(version);
    }

    private async Task ClearMessageLater(int version)
    {
        await Task.Delay(3000);
        if (version != _messageVersion)
        {
            return;
        }

        _message = "";
        await InvokeAsync(StateHasChanged);
    }
}
